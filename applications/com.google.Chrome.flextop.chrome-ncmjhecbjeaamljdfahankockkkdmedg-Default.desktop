Terminal=false
Type=Application
Name=Google Photos
Exec=flatpak 'run' '--command=/app/bin/chrome' 'com.google.Chrome' '--profile-directory=Default' '--app-id=ncmjhecbjeaamljdfahankockkkdmedg'
Icon=chrome-ncmjhecbjeaamljdfahankockkkdmedg-Default
