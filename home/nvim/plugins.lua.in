-- GENERATED by home-manager (home/nvim.nix) from plugins.lua.in.
-- This file carries /nix/store plugin paths (via lazy-nix-helper), so unlike the rest
-- of the nvim config (which stays RAW/live-edit) it is rendered at build time.
-- To change plugins: edit plugins.lua.in and rebuild.

local plugins = {
@pluginTable@
}

-- lazy-nix-helper bootstraps from a hardcoded store path (it cannot resolve itself).
-- Off the Nix closure it falls back to a git clone (portability on non-Nix machines).
local lazy_nix_helper_path = "@lazyNixHelperPath@"
if not vim.uv.fs_stat(lazy_nix_helper_path) then
  lazy_nix_helper_path = vim.fn.stdpath("data") .. "/lazy/lazy-nix-helper.nvim"
  if not vim.uv.fs_stat(lazy_nix_helper_path) then
    vim.fn.system({ "git", "clone", "--filter=blob:none",
      "https://github.com/b-src/lazy-nix-helper.nvim.git", lazy_nix_helper_path })
  end
end
vim.opt.rtp:prepend(lazy_nix_helper_path)

local lnh = require("lazy-nix-helper")
lnh.setup({
  lazypath = vim.fn.stdpath("data") .. "/lazy/lazy.nvim", -- non-Nix fallback only
  input_plugin_table = plugins,
  friendly_plugin_names = true,
})

local lazypath = lnh.lazypath()
vim.opt.rtp:prepend(lazypath)

vim.g.mapleader = " "

-- claude_slash blink.cmp source lives outside the Nix-rendered lua/ tree so its
-- LOGIC is live-editable with no rebuild (same whole-dir-symlink trick as
-- ~/.local/bin/annex-pick.lua — see home.nix's `home.file.".local/bin"`).
-- Only this one path line needs a rebuild if it ever moves.
package.path = package.path .. ";" .. vim.env.HOME .. "/.local/bin/nvim-lua/?.lua"

local function dir(name) return lnh.get_plugin_path(name) end

require("lazy").setup({
  {
    'mikesmithgh/kitty-scrollback.nvim',
    dir = dir('kitty-scrollback.nvim'),
    enabled = true,
    lazy = true,
    cmd = { 'KittyScrollbackGenerateKittens', 'KittyScrollbackCheckHealth' },
    event = { 'User KittyScrollbackLaunch' },
    config = function()
      require('kitty-scrollback').setup()
    end,
  },
  {
    'tpope/vim-repeat', -- Required for leap.nvim dot-repeats
    dir = dir('vim-repeat'),
  },
  {
    url = 'https://codeberg.org/andyg/leap.nvim',
    dir = dir('leap.nvim'),
    config = function()
      vim.keymap.set({'n', 'x', 'o'}, 's',  '<Plug>(leap-forward)')
      vim.keymap.set({'n', 'x', 'o'}, 'S',  '<Plug>(leap-backward)')
      vim.keymap.set({'n', 'x', 'o'}, 'gs', '<Plug>(leap-from-window)')
    end
  },
  {
    'catgoose/nvim-colorizer.lua',
    dir = dir('nvim-colorizer.lua'),
    config = function()
      require('colorizer').setup()
    end
  },
  {
    "lukas-reineke/indent-blankline.nvim",
    dir = dir('indent-blankline.nvim'),
    main = "ibl",
    opts = {},
    config = function()
      require('plugins.indent_blankline')
    end
  },
  {
    'nvim-treesitter/nvim-treesitter',
    dir = dir('nvim-treesitter'),
    lazy = false,
    build = false, -- grammars are Nix-prebuilt (withPlugins); no :TSUpdate
    config = function()
      -- removed: require('nvim-treesitter').install({...}) — THAT was the network vector.
      -- parsers already on rtp via the Nix-patched install_dir.
      vim.api.nvim_create_autocmd('FileType', {
        pattern = { 'markdown', 'markdown_inline' }, -- 'markdown' added for parity after dropping install()
        callback = function() pcall(vim.treesitter.start) end,
      })
    end
  },
  {
    'nvim-tree/nvim-tree.lua',
    dir = dir('nvim-tree.lua'),
    config = function()
      require('plugins.nvim-tree')
    end
  },
  {
    'lewis6991/gitsigns.nvim',
    dir = dir('gitsigns.nvim'),
    dependencies = { { 'nvim-lua/plenary.nvim', dir = dir('plenary.nvim') } },
    config = function()
      require('plugins.gitsigns')
    end
  },
  {
    'nvim-telescope/telescope.nvim',
    dir = dir('telescope.nvim'),
    dependencies = { { 'nvim-lua/plenary.nvim', dir = dir('plenary.nvim') } },
    config = function()
      require('plugins.telescope')
    end
  },
  {
    'akinsho/bufferline.nvim',
    dir = dir('bufferline.nvim'),
    config = function()
      require('bufferline').setup({
        options = {
          hover = {
            enabled = true,
            delay = 200,
            reveal = {'close'}
          }
        },
        highlights = {
          fill = {
            bg = "#000000"
          },
          background = {
            bg = "#000000"
          }
        }
      })
    end
  },
  {
   'catppuccin/nvim',
   name = 'catppuccin',
   dir = dir('catppuccin'),
   config = function()
     require('catppuccin').setup({
       flavour = "mocha",
       transparent_background = true,
       color_overrides = {
         mocha = {
           base = "#000000",
           mantle = "#000000",
           crust = "#000000",
           text = "#EAECF0",
           subtext1 = "#D3D7DE",
           overlay1 = "#818898",
           red = "#F47B85",
           green = "#9BE963",
           blue = "#70B8FF",
           mauve = "#CC7BF4",
           peach = "#FBAD60",
           teal = "#5EEDED",
         },
       },
       custom_highlights = function(colors)
         local U = require("catppuccin.utils.colors")
         local bg_amount = 0.095
         local rainbow = {
           colors.blue,   -- rainbow1 (H1)
           colors.peach,  -- rainbow2 (H2)
           colors.green,  -- rainbow3 (H3)
           colors.teal,   -- rainbow4 (H4)
           colors.yellow, -- rainbow5 (H5)
           colors.mauve,  -- rainbow6 (H6)
         }
         local highlights = {}
         for i, color in ipairs(rainbow) do
           highlights["rainbow" .. i] = { fg = color }
           highlights["RenderMarkdownH" .. i] = { fg = color, bold = true }
           highlights["RenderMarkdownH" .. i .. "Bg"] = { bg = U.darken(color, bg_amount, colors.base) }
         end
         highlights["RenderMarkdownCode"] = { bg = U.darken(colors.text, 0.05, colors.base) }
         highlights["RenderMarkdownCodeInline"] = { fg = colors.peach }
         highlights["RenderMarkdownBullet"] = { fg = colors.blue }
         highlights["RenderMarkdownDash"] = { fg = colors.overlay1 }
         highlights["RenderMarkdownQuote"] = { fg = colors.overlay1 }
         highlights["RenderMarkdownLink"] = { fg = colors.blue }
         highlights["RenderMarkdownChecked"] = { fg = colors.green }
         highlights["RenderMarkdownUnchecked"] = { fg = colors.overlay1 }
         highlights["RenderMarkdownTableHead"] = { fg = colors.blue }
         highlights["RenderMarkdownTableRow"] = { fg = colors.subtext1 }
         -- catppuccin's default Underlined has no fg (just the underline style),
         -- so man pages, :help tags, etc. render in plain text color instead of
         -- the Claude-blue used everywhere else for links/URLs.
         highlights["Underlined"] = { fg = colors.blue, style = { "underline" } }
         return highlights
       end,
       integrations = {
         render_markdown = true,
       },
     })
     vim.cmd.colorscheme "catppuccin"
   end
  },
  {
    'windwp/nvim-autopairs',
    dir = dir('nvim-autopairs'),
    config = function()
      require('nvim-autopairs').setup()
    end
  },
  {
    "folke/twilight.nvim",
    dir = dir('twilight.nvim'),
    config = function()
      require("twilight").setup()
    end
  },
  {
    "folke/zen-mode.nvim",
    dir = dir('zen-mode.nvim'),
    config = function()
      require("zen-mode").setup({
        window = {
          width = 90,
          options = {
            signcolumn = "no",
            number = false,
            relativenumber = false,
            cursorline = false,
          },
        },
        plugins = {
          twilight = { enabled = true },
          kitty = {
            enabled = true,
            font = "+2",
          },
          gitsigns = { enabled = false },
        },
      })
    end
  },
  {
    'MeanderingProgrammer/render-markdown.nvim',
    dir = dir('render-markdown.nvim'),
    dependencies = {
      { 'nvim-treesitter/nvim-treesitter', dir = dir('nvim-treesitter') },
      { 'nvim-tree/nvim-web-devicons', dir = dir('nvim-web-devicons') }
    },
    ft = {'markdown'},
    opts = {
      file_types = { 'markdown' },
    }
  },
  -- Git integration stack (ordered by dependency)
  {
    "sindrets/diffview.nvim",
    dir = dir('diffview.nvim'),
    dependencies = {
      { "nvim-lua/plenary.nvim", dir = dir('plenary.nvim') },
      { "nvim-tree/nvim-web-devicons", dir = dir('nvim-web-devicons') },
    },
    cmd = { "DiffviewOpen", "DiffviewClose", "DiffviewToggleFiles", "DiffviewFocusFiles" },
    config = function()
      require("diffview").setup({
        default_args = {
          DiffviewOpen = { '--imply-local' },
        },
        keymaps = {
          view = {
            { 'n', 'q', '<cmd>DiffviewClose<cr>', { desc = 'Close diffview' } },
          },
          file_panel = {
            { 'n', 'q', '<cmd>DiffviewClose<cr>', { desc = 'Close diffview' } },
          },
          file_history_panel = {
            { 'n', 'q', '<cmd>DiffviewClose<cr>', { desc = 'Close diffview' } },
          },
        },
      })
      vim.opt.fillchars:append { diff = "╱" }
      vim.api.nvim_create_autocmd('User', {
        pattern = 'DiffviewViewLeave',
        callback = function()
          vim.cmd ':DiffviewClose'
        end,
      })
    end
  },
  {
    "NeogitOrg/neogit",
    dir = dir('neogit'),
    dependencies = {
      { "nvim-lua/plenary.nvim", dir = dir('plenary.nvim') },
      { "sindrets/diffview.nvim", dir = dir('diffview.nvim') },
      { "nvim-telescope/telescope.nvim", dir = dir('telescope.nvim') },
    },
    cmd = "Neogit",
    config = function()
      require('plugins.neogit')
    end
  },
  {
    "pwntester/octo.nvim",
    dir = dir('octo.nvim'),
    dependencies = {
      { "nvim-lua/plenary.nvim", dir = dir('plenary.nvim') },
      { "nvim-telescope/telescope.nvim", dir = dir('telescope.nvim') },
      { "nvim-tree/nvim-web-devicons", dir = dir('nvim-web-devicons') },
    },
    cmd = "Octo",
    config = function()
      require("octo").setup()
      vim.treesitter.language.register('markdown', 'octo')
    end
  },
  {
    "HakonHarnes/img-clip.nvim",
    dir = dir('img-clip.nvim'),
    event = "BufEnter",
    opts = {
      default = {
        relative_to_current_file = true,
        dir_path = function()
          local file_dir = vim.fn.expand('%:p:h')
          local images_dir = file_dir .. '/images'
          vim.fn.mkdir(images_dir, 'p')
          return 'images'
        end,
        extension = "png",
        prompt_for_file_name = true,
      },
      filetypes = {
        markdown = {
          url_encode_path = true,
          template = "![$CURSOR]($FILE_PATH)",
          download_images = true,
        },
      },
    }
  },
  {
    "3rd/image.nvim",
    dir = dir('image.nvim'),
    build = false,
    opts = {
        backend = "kitty",
        processor = "magick_cli",
        integrations = {
            markdown = {
                enabled = true,
                clear_in_insert_mode = false,
                download_remote_images = true,
                only_render_image_at_cursor = false,
            }
        },
        editor_only_render_when_focused = false,
        window_overlap_clear_enabled = false,
        hijack_file_patterns = { "*.png", "*.jpg", "*.jpeg", "*.gif", "*.webp", "*.avif" },
    },
  },
  {
    "karb94/neoscroll.nvim",
    dir = dir('neoscroll.nvim'),
    event = "BufRead",
    config = function()
      require('plugins.neoscroll')
    end
  },
  {
    'nvim-lualine/lualine.nvim',
    dir = dir('lualine.nvim'),
    dependencies = {
      { 'nvim-tree/nvim-web-devicons', dir = dir('nvim-web-devicons') },
      { 'catppuccin/nvim', dir = dir('catppuccin') }
    },
    config = function()
      require('plugins.lualine').setup()
    end,
    event = 'VeryLazy',
  },

  -- pipeline.nvim — CI/CD viewer (uses yq, Nix-provided)
  {
    "topaxi/pipeline.nvim",
    dir = dir('pipeline.nvim'),
    keys = {
      { "<leader>ci", "<cmd>Pipeline<cr>", desc = "Open pipeline.nvim" },
    },
    opts = {},
  },

  -- diagram.nvim — live diagram rendering (mermaid/plantuml/d2/gnuplot, all Nix-provided)
  {
    "3rd/diagram.nvim",
    dir = dir('diagram.nvim'),
    dependencies = { { "3rd/image.nvim", dir = dir('image.nvim') } },
    opts = {
      events = {
        render_buffer = { "InsertLeave", "BufWinEnter", "TextChanged" },
        clear_buffer = { "BufLeave" },
      },
      renderer_options = {
        mermaid = { theme = "default", scale = 1 },
        plantuml = { charset = "utf-8" },
        d2 = {},
        gnuplot = {},
      },
    },
  },

  -- mason REMOVED (imperative runtime installs — forbidden). marksman is Nix-provided
  -- on PATH; nvim-lspconfig just ships the lsp/marksman.lua definition, enabled via
  -- the native Nvim 0.11 API (require('lspconfig').<server>.setup{} is deprecated as
  -- of nvim-lspconfig 2.10 — see :help lspconfig-nvim-0.11).
  {
    "neovim/nvim-lspconfig",
    dir = dir('nvim-lspconfig'),
    ft = { "markdown", "md" },
    config = function()
      -- The ~/mecattaf/notes vault is ~10k markdown files / 5.4G. marksman roots
      -- to its .git and tries to index the whole tree, times out
      -- (MailboxProcessor.PostAndAsyncReply) and crashes on every open. Skip
      -- attaching inside the vault; marksman still works in normal md projects.
      local vault = vim.env.HOME .. "/mecattaf/notes"
      vim.lsp.config("marksman", {
        root_dir = function(bufnr, on_dir)
          local fname = vim.api.nvim_buf_get_name(bufnr)
          if fname:sub(1, #vault + 1) == vault .. "/" then return end
          on_dir(vim.fs.root(bufnr, { ".marksman.toml", ".git" })
            or vim.fs.dirname(fname))
        end,
      })
      vim.lsp.enable("marksman")
    end,
  },

  -- filemention.nvim — @-mention files (Claude Code style). Completion-source
  -- only, so blink.cmp below is its engine; fd/rg finders are Nix-provided.
  {
    "not-manu/filemention.nvim",
    dir = dir('filemention.nvim'),
    event = "InsertEnter",
    opts = {},
  },
  {
    "saghen/blink.cmp",
    dir = dir('blink.cmp'),
    event = "InsertEnter",
    dependencies = { { "not-manu/filemention.nvim", dir = dir('filemention.nvim') } },
    opts = {
      -- filemention (`@`) and claude_slash (`/`) are the ONLY sources: the menu
      -- appears solely on those triggers in markdown/text/gitcommit (both gate
      -- by filetype internally) — no general autocomplete noise. <C-y> accepts,
      -- <C-n>/<C-p> navigate (default preset).
      keymap = { preset = "default" },
      cmdline = { enabled = false },
      fuzzy = {
        implementation = "prefer_rust_with_warning", -- rust lib is Nix-prebuilt in the plugin dir
        prebuilt_binaries = { download = false },    -- never fetch at runtime
      },
      sources = {
        default = { "filemention", "claude_slash" },
        providers = {
          filemention = { name = "filemention", module = "filemention.sources.blink" },
          -- claude_slash is a module on package.path (see above), NOT a lazy
          -- plugin dir — it must stay out of nvim.nix's lazyPlugins/expected
          -- allowlist below (those enumerate real /nix/store plugin dirs).
          claude_slash = { name = "claude_slash", module = "claude_slash" },
        },
      },
    },
  },

  -- web-clipper.nvim — URL → cleaned Markdown in ~/Documents/clippings/.
  -- Upstream's `build = "npm install --prefix bin"` is skipped: node_modules is
  -- vendored in the plugin and node is pinned via Nix shebang patch (nvim.nix).
  {
    "jbuck95/web-clipper.nvim",
    dir = dir('web-clipper.nvim'),
    build = false,
    cmd = "WebClipper",
    keys = {
      -- <leader>w* chosen over upstream's <leader>m* (taken by Minimal())
      { "<leader>wc", "<Plug>(WebClipperClip)", mode = { "n", "v" }, desc = "Web clip: URL (selection/clipboard/prompt)" },
      { "<leader>ws", "<Plug>(WebClipperClipSite)", desc = "Web clip: pick configured site" },
    },
    opts = {},
  },

}, {
  install = { missing = false }, -- never auto-install at startup
  pkg = { enable = false },
  rocks = { enabled = false },   -- no luarocks network; image.nvim's magick rock comes from Nix
  change_detection = { enabled = false },
})

-- Fail-closed: any store-resolution miss is otherwise SILENT (install.missing=false).
-- Only assert on the Nix closure (off-Nix, clones are allowed).
if vim.uv.fs_stat("@lazyNixHelperPath@") then
  local expected = {
    "kitty-scrollback.nvim","vim-repeat","leap.nvim","nvim-colorizer.lua",
    "indent-blankline.nvim","nvim-treesitter","nvim-tree.lua","gitsigns.nvim",
    "plenary.nvim","telescope.nvim","bufferline.nvim","catppuccin","nvim-autopairs",
    "twilight.nvim","zen-mode.nvim","render-markdown.nvim","nvim-web-devicons",
    "diffview.nvim","neogit","octo.nvim","img-clip.nvim","image.nvim","neoscroll.nvim",
    "lualine.nvim","pipeline.nvim","diagram.nvim","nvim-lspconfig",
    "filemention.nvim","blink.cmp","web-clipper.nvim",
  }
  local cfg = require("lazy.core.config").plugins
  for _, name in ipairs(expected) do
    local p = cfg[name]
    assert(p and p.dir and p.dir:match("^/nix/store/"),
      "lazy-nix-helper MISS: " .. name .. " not resolved from /nix/store (dir=" .. tostring(p and p.dir) .. ")")
  end
end
