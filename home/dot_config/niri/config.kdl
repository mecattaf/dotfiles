include "input.kdl"
include "layout.kdl"
include "binds.kdl"
include "window-rules.kdl"
include "layer-rules-webshell.kdl"
include "misc.kdl"
include "startup.kdl"

// local overrides (tracked in-repo; per-host blocks stay commented out there)
// NIX-MIGRATION: was `include optional=true "local.kdl"` — the pinned niri 25.11
// does not know `optional=true` and a parse error makes niri silently discard the
// ENTIRE config (defaults-only boot). local.kdl exists in-repo and is deployed by
// the same whole-dir home-manager symlink, so optionality is not needed.
include "local.kdl"

// Per-HOST niri config, generated by home.nix (xdg.configFile."niri-local.kdl").
// Absolute path: this file lives OUTSIDE the whole-dir out-of-store symlink so it
// can differ per host; niri include does NOT expand ~ or $HOME, and `optional` is
// unavailable on the pinned niri, so home.nix writes it on EVERY host (empty on the
// Strix desktops, per-device touch → output blocks on the zenbook-duo). Currently
// carries the zenbook's dual-touchscreen mapping (PR #1856 syntax). See dotfiles#67.
include "/home/tom/.config/niri-local.kdl"
