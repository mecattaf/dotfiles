// NIX-MIGRATION: placed RAW (home-manager out-of-store symlink) to keep niri
// hot-reload. Candidate to port to typed programs.niri.settings (niri-flake)
// later. Decision + rationale: ~/mecattaf/nix-decisions.md (D1).

// -- WebShell Layer Rules --
// Include from config.kdl:  include "layer-rules.kdl"
//
// All webshell surfaces use the namespace prefix "shell:"
// Matches PanelWindow { WlrLayerShell.namespace: "shell:bar" } etc. in QML.

// Bar -- top panel. Blocked from screen capture.
layer-rule {
    match namespace="shell:bar"
    block-out-from "screen-capture"
}

// Dock -- bottom dock. Blocked from screen capture.
layer-rule {
    match namespace="shell:dock"
    block-out-from "screen-capture"
}

// OSD -- transient volume/brightness overlays
layer-rule {
    match namespace="shell:osd"
}

// Notifications -- popup overlays
layer-rule {
    match namespace="shell:notifications"
}

// Overlay -- launcher/spotlight, fullscreen translucent
layer-rule {
    match namespace="shell:overlay"
}

// CCD sidebar -- control center / dashboard
layer-rule {
    match namespace="shell:ccd"
}

// Lockscreen -- above all other surfaces
layer-rule {
    match namespace="shell:lockscreen"
}

