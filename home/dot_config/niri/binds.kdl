// NIX-MIGRATION: placed RAW (home-manager out-of-store symlink) to keep niri
// hot-reload. Candidate to port to typed programs.niri.settings (niri-flake)
// later. Decision + rationale: ~/mecattaf/nix-decisions.md (D1).

binds {
    // scroll: floating_modifier $mod normal
    // ^ niri handles floating drag natively


    // ── Application Launchers ────────────────────────────────────

    // scroll: bindsym $mod+Return exec kitty -e fish
    Mod+Return hotkey-overlay-title="Terminal" { spawn "kitty" "-e" "fish"; }

    // scroll: bindsym $mod+Shift+Return exec $scripts/nvim-terminal.sh
    // niri: same script, ported to shell + niri msg; host-aware
    //   coordinator: new kitty in focused kitty/nvim's cwd
    //   remote (worker / zenbook): new kitty that SSHs to coordinator via `desk`
    Mod+Shift+Return hotkey-overlay-title="Terminal (smart)" { spawn-sh "~/.local/bin/new-terminal"; }

    // Resume an existing zmx session via fzf picker; runs locally on the
    // coordinator, attaches the coordinator's sessions over kitten ssh on remotes.
    Mod+Ctrl+Shift+Return hotkey-overlay-title="Terminal (resume)" { spawn-sh "~/.local/bin/resume-terminal"; }

    // scroll: bindsym $mod+D exec vicinae open
    Mod+D hotkey-overlay-title="Launcher" { spawn-sh "~/.local/bin/launcher"; }
    Mod+Shift+D hotkey-overlay-title="DMS Launcher" { spawn-sh "~/.local/bin/dms-launcher"; }

    // scroll: bindsym $mod+E exec thunar
    Mod+E hotkey-overlay-title="File Manager" { spawn "nautilus"; }

    // scroll: bindsym Ctrl+N exec flatpak run com.google.Chrome
    // scroll: bindsym Ctrl+Shift+N exec flatpak run com.google.Chrome --incognito
    // NIX-MIGRATION: flatpak is GONE (nix-decisions.md: google-chrome from
    // nixpkgs, no flatpak). flatpak run com.google.Chrome → google-chrome-stable.
    // NOTE: the bare Ctrl+N / Ctrl+Shift+N grabs are global compositor launchers
    // (restored by request). They shadow the focused app's own Ctrl+N — nvim
    // completion, Chrome's native new-window/incognito, etc. — everywhere. The
    // Mod-layer bindings below are kept as a conflict-free alternative.
    Ctrl+N hotkey-overlay-title="Chrome" { spawn "google-chrome-stable"; }
    Ctrl+Shift+N hotkey-overlay-title="Chrome (incognito)" { spawn "google-chrome-stable" "--incognito"; }
    Mod+N hotkey-overlay-title="Chrome" { spawn "google-chrome-stable"; }
    Mod+Ctrl+N hotkey-overlay-title="Chrome (incognito)" { spawn "google-chrome-stable" "--incognito"; }


    // ── Quickshell (was DMS) ─────────────────────────────────────

Mod+V hotkey-overlay-title="Clipboard" { spawn-sh "~/.local/bin/clipboard"; }
    Mod+Shift+V hotkey-overlay-title="Emoji Picker" { spawn "rofimoji" "-a" "clipboard"; }
    Mod+O hotkey-overlay-title="Notifications" { spawn-sh "~/.local/bin/dnd"; }
    Mod+Comma hotkey-overlay-title="Settings" { spawn-sh "~/.local/bin/settings"; }
    Mod+B hotkey-overlay-title="Control Center" { spawn-sh "~/.local/bin/control-center"; }


    // ── Screenshots ──────────────────────────────────────────────

    Mod+S hotkey-overlay-title="Screenshot" { screenshot-screen; }
    Mod+Shift+S hotkey-overlay-title="Screenshot Area" { screenshot; }
    Mod+Alt+S hotkey-overlay-title="Screenshot Window" { screenshot-window; }


    // ── Color Picker ─────────────────────────────────────────────

    // scroll: set $color-picker exec $scripts/colorpicker
    // scroll: bindsym $mod+C exec $color-picker
    // ^ Use niri IPC for color picking:
    Mod+C hotkey-overlay-title="Color Picker" { spawn-sh "~/.local/bin/colorpicker"; }


    // ── Media & Hardware Keys (F1-F10) ───────────────────────────

    F1 hotkey-overlay-title="Brightness Down" { spawn-sh "~/.local/bin/brightness down"; }
    F2 hotkey-overlay-title="Brightness Up" { spawn-sh "~/.local/bin/brightness up"; }
    // Shift = adjust ONLY the focused screen's backlight (zenbook-duo dual eDP;
    // `focused` maps niri's focused output -> its backlight generically, so this
    // is harmless/degrades to default on single-screen hosts).
    Shift+F1 hotkey-overlay-title="Brightness Down (focused screen)" { spawn-sh "~/.local/bin/brightness down focused"; }
    Shift+F2 hotkey-overlay-title="Brightness Up (focused screen)" { spawn-sh "~/.local/bin/brightness up focused"; }
    F3 hotkey-overlay-title="Play/Pause" { spawn-sh "~/.local/bin/media play"; }
    F4 hotkey-overlay-title="Previous" { spawn-sh "~/.local/bin/media prev"; }
    F5 hotkey-overlay-title="Next" { spawn-sh "~/.local/bin/media next"; }
    F6 hotkey-overlay-title="Mute" { spawn-sh "~/.local/bin/volume mute"; }
    F7 hotkey-overlay-title="Volume Down" { spawn-sh "~/.local/bin/volume down"; }
    F8 hotkey-overlay-title="Volume Up" { spawn-sh "~/.local/bin/volume up"; }
    F9 hotkey-overlay-title="Pomodoro" { spawn-sh "~/.local/bin/pomodoro menu"; }
    F10 hotkey-overlay-title="Sleep Monitors" { spawn-sh "kitty --class sleep-monitors-prompt -e ~/.config/niri/scripts/sleep-monitors"; }


    // ── Chrome Webapps ───────────────────────────────────────────

    // scroll: set $chrome flatpak run com.google.Chrome
    // NIX-MIGRATION: flatpak is GONE (nix-decisions.md: google-chrome from
    // nixpkgs, unfree; OBS via programs.obs-studio). All `flatpak run
    // com.google.Chrome` → google-chrome-stable, com.obsproject.Studio → obs.

    // scroll: bindsym $mod+Shift+N exec $chrome --app=https://chat.openai.com/
    Mod+Shift+N { spawn "google-chrome-stable" "--app=https://chat.openai.com/"; }
    // scroll: bindsym $mod+Shift+C exec $chrome --app=https://claude.ai/
    Mod+Shift+C { spawn "google-chrome-stable" "--app=https://claude.ai/"; }
    // scroll: bindsym $mod+Shift+M exec $chrome --app=https://soundcloud.com
    // Music pane — a piri right-side auto-scratchpad (config: niri/piri.toml
    // [scratchpads.music]; daemon: home/piri.nix). Mod+M toggles it: first press
    // (nothing captured) spawns the SoundCloud PWA pinned to the right, later
    // presses show/hide. Mod+Shift+M captures whatever window is focused INTO the
    // music pane — the "mark this as my music window" move, for the coming
    // cliamp-in-kitty setup (focus the cliamp window, Mod+Shift+M, then Mod+M
    // toggles it thereafter).
    Mod+M hotkey-overlay-title="Music (toggle)" { spawn "piri" "scratchpads" "music" "toggle"; }
    Mod+Shift+M hotkey-overlay-title="Music (capture focused)" { spawn "piri" "scratchpads" "music" "add" "fromRight"; }
    // SUPERSEDED by the music scratchpad above (Mod+M was YouTube-Music-focus).
    // Kept for reference — the jq/focus-window-by-app_id idiom is reused elsewhere:
    // Mod+M { spawn-sh "niri msg -j windows | jq -re 'map(select(.app_id == \"chrome-music.youtube.com__-Default\"))[0].id // empty' | xargs --no-run-if-empty -I{} niri msg action focus-window --id {}"; }
    // scroll: bindsym $mod+Shift+W exec $chrome --app=https://mail.google.com/
    Mod+Shift+W { spawn "google-chrome-stable" "--app=https://mail.google.com/"; }
    // scroll: bindsym $mod+Shift+semicolon exec flatpak run com.obsproject.Studio
    Mod+Shift+Semicolon { spawn "obs"; }
    // scroll: bindsym $mod+Shift+period exec $chrome --app=https://calendar.notion.so/
    Mod+Shift+Period { spawn "google-chrome-stable" "--app=https://calendar.notion.so/"; }
    // scroll: bindsym $mod+Shift+E exec $chrome --app=https://drive.google.com/drive/u/0/
    // ^ DROPPED: conflicts with quit


    // ── Utilities ────────────────────────────────────────────────

    // scroll: set $start-wshowkeys wshowkeys -F "JetBrainsMono Nerd Font 16" -a bottom
    // scroll: bindsym $mod+apostrophe exec $start-wshowkeys
    Mod+Apostrophe hotkey-overlay-title="Show Keys" { spawn-sh "wshowkeys -F 'JetBrainsMono Nerd Font 16' -a bottom"; }
    // scroll: set $stop-wshowkeys pkill wshowkeys
    // scroll: bindsym $mod+Shift+apostrophe exec $stop-wshowkeys
    Mod+Shift+Apostrophe { spawn-sh "pkill wshowkeys"; }

    Mod+I hotkey-overlay-title="Toggle Top Bar" { spawn-sh "~/.local/bin/bar-toggle"; }

    // Hold Mod+Space = push-to-talk: asr-rs watches the chord passively at
    // the evdev layer, BELOW niri. This bind is a consume-only no-op — it
    // must do nothing (asr-rs handles activation), but it must EXIST so niri
    // swallows the chord and its auto-repeat: apps that treat Super+Space as
    // plain space (browsers; kitty ignores it) would otherwise get spaces
    // typed into them for the whole hold.
    Mod+Space repeat=false hotkey-overlay-title="Dictate (hold)" { spawn "true"; }
    Mod+Shift+Space hotkey-overlay-title="Stop Dictation" { spawn "pkill" "-USR2" "asr-rs"; }

    Mod+Slash { show-hotkey-overlay; }


    // ── Window Management ────────────────────────────────────────

    // scroll: bindsym $mod+Shift+Q kill
    Mod+Shift+Q { close-window; }

    // scroll: bindsym $mod+Tab floating toggle
    Mod+Tab { toggle-window-floating; }

    // scroll: bindsym $mod+Shift+Tab focus mode_toggle
    Mod+Shift+Tab { switch-focus-between-floating-and-tiling; }

    // scroll: bindsym $mod+grave layout_transpose
    // ^ DROPPED: no niri equivalent


    // ── Focus Navigation ─────────────────────────────────────────

    // scroll: bindsym $mod+h     focus  left
    Mod+H { focus-column-left; }
    // scroll: bindsym $mod+j     focus  down
    Mod+J { focus-window-down; }
    // scroll: bindsym $mod+k     focus  up
    Mod+K { focus-window-up; }
    // scroll: bindsym $mod+l     focus  right
    Mod+L { focus-column-right; }

    // scroll: bindsym $mod+home  focus  beginning
    Mod+Home { focus-column-first; }
    // scroll: bindsym $mod+end   focus  end
    Mod+End  { focus-column-last; }


    // ── Window/Column Movement ───────────────────────────────────

    // scroll: bindsym $mod+Shift+h move left nomode
    Mod+Shift+H { consume-or-expel-window-left; }
    // scroll: bindsym $mod+Shift+l move right nomode
    Mod+Shift+L { consume-or-expel-window-right; }

    // scroll: bindsym $mod+Shift+j move container to output down; focus output down
    Mod+Shift+J { move-column-to-monitor-down; }
    // scroll: bindsym $mod+Shift+k move container to output up; focus output up
    Mod+Shift+K { move-column-to-monitor-up; }

    // scroll: bindsym $mod+Alt+j move down nomode
    Mod+Alt+J { move-window-down; }
    // scroll: bindsym $mod+Alt+k move up nomode
    Mod+Alt+K { move-window-up; }

    // scroll: bindsym $mod+Alt+h move left monitor
    Mod+Alt+H { move-column-to-monitor-left; }
    // scroll: bindsym $mod+Alt+l move right monitor
    Mod+Alt+L { move-column-to-monitor-right; }

    // addon: monitor movement (stacked layout)
    Alt+J { focus-monitor-down; }
    Alt+K { focus-monitor-up; }


    // ── Column/Window Sizing ─────────────────────────────────────

    // scroll: bindsym $mod+f        cycle_size h next
    Mod+F { switch-preset-column-width; }
    // scroll: bindsym $mod+Shift+f  cycle_size h prev
    Mod+Shift+F { switch-preset-column-width-back; }

    // scroll: bindsym $mod+g        cycle_size v next
    Mod+G { switch-preset-window-height; }
    // scroll: bindsym $mod+Shift+g  cycle_size v prev
    Mod+Shift+G { switch-preset-window-height-back; }

    Mod+Minus { set-column-width "-10%"; }


    // ── Fullscreen ───────────────────────────────────────────────

    // scroll: bindsym $mod+equal fullscreen_application toggle
    Mod+Equal { fullscreen-window; }
    // scroll: bindsym $mod+Shift+equal fullscreen toggle
    Mod+Shift+Equal { maximize-column; }
    // scroll: bindsym $mod+Ctrl+equal fullscreen_application reset
    // ^ DROPPED: fullscreen-window is a toggle in niri

    Mod+Ctrl+F { maximize-window-to-edges; }


    // ── Gap Adjustment ───────────────────────────────────────────

    Mod+Page_Up repeat=false { toggle-overview; }
    Mod+Page_Down repeat=false { toggle-overview; }
    Mod+Alt+Up repeat=false { toggle-overview; }
    Mod+Alt+Down repeat=false { toggle-overview; }

    // scroll: bindsym $mod+Ctrl+Page_Up scale_workspace reset
    // ^ DROPPED
    // scroll: bindsym $mod+Ctrl+Page_Down scale_workspace overview
    // ^ see Mod+Ctrl+O toggle-overview below


    // ── Workspace Navigation ─────────────────────────────────────

    // scroll: bindsym $mod+1 $mark-toggle 1  (smart marks — all 30 bindings dropped)
    // scroll: bindsym $mod+Shift+1 $mark-clear 1
    // scroll: bindsym $mod+Ctrl+1 $mark-show 1
    // ^ DROPPED: Lua smart marks system. Mod+1-9 repurposed for workspaces.
    Mod+1 { focus-workspace 1; }
    Mod+2 { focus-workspace 2; }
    Mod+3 { focus-workspace 3; }
    Mod+4 { focus-workspace 4; }
    Mod+5 { focus-workspace 5; }
    Mod+6 { focus-workspace 6; }
    Mod+7 { focus-workspace 7; }
    Mod+8 { focus-workspace 8; }
    Mod+9 { focus-workspace 9; }
    Mod+Ctrl+1 { move-column-to-workspace 1; }
    Mod+Ctrl+2 { move-column-to-workspace 2; }
    Mod+Ctrl+3 { move-column-to-workspace 3; }
    Mod+Ctrl+4 { move-column-to-workspace 4; }
    Mod+Ctrl+5 { move-column-to-workspace 5; }
    Mod+Ctrl+6 { move-column-to-workspace 6; }
    Mod+Ctrl+7 { move-column-to-workspace 7; }
    Mod+Ctrl+8 { move-column-to-workspace 8; }
    Mod+Ctrl+9 { move-column-to-workspace 9; }

    Mod+Down { focus-workspace-down; }
    Mod+Up { focus-workspace-up; }
    Mod+Shift+Down { move-column-to-workspace-down; }
    Mod+Shift+Up { move-column-to-workspace-up; }

    Mod+WheelScrollDown      cooldown-ms=150 { focus-workspace-down; }
    Mod+WheelScrollUp        cooldown-ms=150 { focus-workspace-up; }
    Mod+Ctrl+WheelScrollDown cooldown-ms=150 { move-column-to-workspace-down; }
    Mod+Ctrl+WheelScrollUp   cooldown-ms=150 { move-column-to-workspace-up; }
    Mod+WheelScrollRight { focus-column-right; }
    Mod+WheelScrollLeft  { focus-column-left; }


    // ── Niri-specific (no scroll origin) ─────────────────────────

    Mod+W { toggle-column-tabbed-display; }
    Mod+BracketLeft  { consume-or-expel-window-left; }
    Mod+BracketRight { consume-or-expel-window-right; }

    Mod+Ctrl+O repeat=false { toggle-overview; }
    Mod+Ctrl+R { reset-window-height; }
    Mod+Escape allow-inhibiting=false { toggle-keyboard-shortcuts-inhibit; }
    Mod+Shift+P { power-off-monitors; }


    // ── Dropped scroll-specific (no port) ────────────────────────
    // scroll: bindsym $mod+BackSpace set_mode
    // scroll: bindsym $mod+grave layout_transpose
    // scroll: #bindsym --no-repeat $mod+slash jump
    // scroll: jump_labels_color $cl_high
    // scroll: jump_labels_scale 0.5
    // scroll: jump_labels_keys asdfghjkl;
    // scroll: bindgesture { swipe:3:right exec $scripts/gestures backward ... }
    // scroll: bindgesture { pinch:4:outward jump ... }
    // scroll: bindsym $mod+Shift+Return exec $scripts/nvim-terminal.sh
    //   ^ all used scrollmsg or scroll Lua engine — no niri equivalent
}
