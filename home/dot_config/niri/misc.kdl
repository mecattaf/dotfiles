// NIX-MIGRATION: placed RAW (home-manager out-of-store symlink) to keep niri
// hot-reload. Candidate to port to typed programs.niri.settings (niri-flake)
// later. Decision + rationale: ~/mecattaf/nix-decisions.md (D1).

// scroll: animations {
// scroll:   enabled yes
// scroll:   frequency_ms 16
// scroll:   style clip
// scroll:   default yes 120 var 3 [ 0.25 0.1 0.25 1 ]
// scroll:   window_move yes 120 var 3 [ 0.25 0.1 0.25 1 ]
// scroll:   window_open yes 100 var 3 [ 0.3 0 0.7 1 ]
// scroll:   window_size yes 120 var 3 [ 0.25 0.1 0.25 1 ]
// scroll: }
// ^ niri uses a completely different animation system.
// See: https://github.com/YaLTeR/niri/wiki/Configuration:-Animations
animations {
    // Workspace vertical navigation — tuned for 120Hz (~35ms feel)
    workspace-switch {
        spring damping-ratio=1.0 stiffness=3000 epsilon=0.001
    }

    // Synchronized movement group — all three must be identical (niri drives them together
    // when a resize causes a view scroll, or window-open causes columns to reflow).
    // stiffness=5000 epsilon=0.001: ~25ms feel, 3 frames @ 120Hz
    horizontal-view-movement {
        spring damping-ratio=1.0 stiffness=5000 epsilon=0.001
    }

    window-movement {
        spring damping-ratio=1.0 stiffness=5000 epsilon=0.001
    }

    window-resize {
        spring damping-ratio=1.0 stiffness=5000 epsilon=0.001
    }

    // Overview zoom — deliberately slower: dramatic zoom benefits from ~80ms feel
    overview-open-close {
        spring damping-ratio=1.0 stiffness=1500 epsilon=0.001
    }

    // Window open/close — 25ms: 3 frames @ 120Hz, ease-out for snappy feel
    window-open {
        duration-ms 25
        curve "ease-out-expo"
    }

    window-close {
        duration-ms 25
        curve "ease-out-quad"
    }

    // Screenshot UI
    screenshot-ui-open {
        duration-ms 25
        curve "ease-out-quad"
    }

    // Overlay notifications — bouncy spring (damping-ratio=0.6) draws attention, niri design intent
    config-notification-open-close {
        spring damping-ratio=0.6 stiffness=1000 epsilon=0.001
    }

    exit-confirmation-open-close {
        spring damping-ratio=0.6 stiffness=500 epsilon=0.01
    }

    // Recent windows switcher
    recent-windows-close {
        spring damping-ratio=1.0 stiffness=3000 epsilon=0.001
    }
}

hotkey-overlay {
    skip-at-startup
}

// scroll: default_border pixel 1
// scroll: default_floating_border normal
prefer-no-csd

screenshot-path "~/Pictures/Screenshots/Screenshot from %Y-%m-%d %H-%M-%S.png"

// scroll: seat seat0 xcursor_theme Bibata-Modern-Classic 48
// scroll: seat seat0 hide_cursor 1000
cursor {
    xcursor-theme "Bibata-Modern-Classic"
    xcursor-size 48
    hide-after-inactive-ms 1000
}

// scroll: font pango:JetBrainsMono Nerd Font 12
// ^ NO NIRI EQUIVALENT: niri uses system fonts for its UI

// scroll: exec systemctl --user import-environment DISPLAY WAYLAND_DISPLAY SWAYSOCK XDG_CURRENT_DESKTOP
// scroll: exec hash dbus-update-activation-environment 2>/dev/null && \
// scroll:         dbus-update-activation-environment --systemd DISPLAY WAYLAND_DISPLAY SWAYSOCK XDG_CURRENT_DESKTOP=sway
// ^ DELETE: niri-session handles env export and D-Bus activation natively
overview {
    backdrop-color "#000000"
}

gestures {
    hot-corners {
        off
    }
}

environment {}
