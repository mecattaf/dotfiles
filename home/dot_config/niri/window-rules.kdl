// NIX-MIGRATION: placed RAW (home-manager out-of-store symlink) to keep niri
// hot-reload. Candidate to port to typed programs.niri.settings (niri-flake)
// later. Decision + rationale: ~/mecattaf/nix-decisions.md (D1).

// Global rounded corners
window-rule {
    geometry-corner-radius 4
    clip-to-geometry true
}

// White border when desk SSH session is active
// Matches window title set by `desk` via `kitty @ set-window-title remote`
// Disabled: green starship arrow + "ssh/tailscale/shpool" prompt segments
// are enough visual indication. Remove the leading `/-` to re-enable.
/-window-rule {
    match app-id="kitty" title="remote"
    border {
        width 2
        active-color "#ffffff"
        inactive-color "#ffffff"
    }
}

// scroll: for_window [app_id="^chrome-.*"] shortcuts_inhibitor disable
// ^ NO NIRI EQUIVALENT: use Mod+Escape to toggle keyboard-shortcuts-inhibit

// scroll: for_window [app_id="io.bassi.Amberol"] border pixel 0, floating enable
window-rule {
    match app-id="io.bassi.Amberol"
    open-floating true
}

// F10 sleep-monitors prompt: small floating kitty popup, focused on open.
// Spawned by niri/binds.kdl F10 binding running niri/scripts/sleep-monitors.
// Orange border = starship's local ❯ color (#DA7756).
window-rule {
    match app-id="sleep-monitors-prompt"
    open-floating true
    open-focused true
    default-column-width { fixed 640; }
    default-window-height { fixed 200; }
    border {
        width 2
        active-color "#DA7756"
        inactive-color "#DA7756"
    }
}

// scroll: for_window [app_id="blueman-manager"] border pixel 0, floating enable, resize 35% 35%, move 63% 60%
window-rule {
    match app-id="blueman-manager"
    open-floating true
    // ^ niri can't set floating size/position via rules
}

// scroll: for_window [app_id="pavucontrol"] border pixel 0, floating enable, resize 35% 35%, move 63% 60%
window-rule {
    match app-id="pavucontrol"
    open-floating true
}

// scroll: for_window [app_id="rofimoji"] border pixel 0, floating enable, resize 35% 35%, move 63% 60%
window-rule {
    match app-id="rofimoji"
    open-floating true
}

// scroll: for_window [app_id="rofi"] border pixel 0, floating enable, resize 35% 35%, move 63% 60%
window-rule {
    match app-id="rofi"
    open-floating true
}

// Firefox Picture-in-Picture
window-rule {
    match app-id=r#"firefox$"# title="^Picture-in-Picture$"
    open-floating true
}

// Wezterm: no default column width
window-rule {
    match app-id=r#"^org\.wezfurlong\.wezterm$"#
    default-column-width {}
}

// Frosted kitty: kitty's background_opacity (0.8) makes the bg translucent;
// niri blur frosts the wallpaper behind it while text stays crisp.
// Enabled in niri 26.04 (Nixpkgs) — blur was not in 25.11.
window-rule {
    match app-id="kitty"
    background-effect {
        blur true
    }
}
