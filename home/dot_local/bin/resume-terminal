#!/usr/bin/env bash
# niri Mod+Ctrl+Shift+Return:
#   - harness-desktop: open a new kitty, fzf-pick a local shpool session, attach.
#   - elsewhere (laptop): open a new kitty that SSHes to harness-desktop and
#     runs the same picker remotely; niri's window-rule renders the white
#     "remote" border once desk-resume sets the window title.
#
# Companion to Mod+Shift+Return (`new-terminal` / `desk`), which always spawns
# a *fresh* shpool session. Use this binding to resume an existing one.

set -u

host="$(hostname)"

if [[ "$host" != "harness-desktop" ]]; then
    exec kitty fish -ic desk-resume
fi

exec kitty -e shpool-resume
