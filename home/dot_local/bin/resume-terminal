#!/usr/bin/env bash
# niri Mod+Ctrl+Shift+Return:
#   - coordinator: open a new kitty, fzf-pick a local zmx session, attach.
#   - elsewhere (worker / zenbook thin-client): open a new kitty whose
#     `desk-resume` lists the coordinator's sessions over ssh, fzf-picks one,
#     and attaches over `kitten ssh ... -t zmx attach`; niri's window-rule
#     renders the white "remote" border once desk-resume sets the window title.
#
# Companion to Mod+Shift+Return (`new-terminal` / `desk`), which always spawns
# a *fresh* session. Use this binding to resume/project an existing one.

set -u

host="$(hostname)"

if [[ "$host" != "coordinator" ]]; then
    exec kitty fish -ic desk-resume
fi

exec kitty -e zmx-resume
