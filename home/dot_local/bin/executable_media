#!/bin/bash
# media -- MPRIS playback control via IPC
# IPC target: music (MprisBridge IpcHandler)
case "$1" in
    play|toggle)  qs ipc --pid $(pgrep -x qs) call music togglePlay ;;
    next)         qs ipc --pid $(pgrep -x qs) call music next ;;
    prev)         qs ipc --pid $(pgrep -x qs) call music previous ;;
    *)            echo "Usage: $0 {play|next|prev}"; exit 1 ;;
esac
