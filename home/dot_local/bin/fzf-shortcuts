#!/bin/bash
# fzf-shortcuts -- fzf shortcut viewer with glow rendering (no quickshell IPC)

markdown_dir="$HOME/.config/niri/scripts/shortcuts"

declare -A file_map=(
    ["nvim"]="nvim.md"
    ["niri"]="niri.md"
    ["terminal"]="terminal.md"
    ["vim"]="vim.md"
    ["fish"]="fish.md"
)

selection=$(printf "%s\n" "${!file_map[@]}" | fzf --reverse --header "Shortcut Menu")

if [ -n "$selection" ]; then
    file="$markdown_dir/${file_map[$selection]}"
    if [ -f "$file" ]; then
        glow -p "$file"
    else
        echo "File not found: $file"
    fi
else
    echo "No selection made."
fi
