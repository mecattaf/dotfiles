#!/bin/bash
# media -- MPRIS playback control
# NIX-MIGRATION: D2 native re-point (ratified 2026-06-20, nix-decisions.md /
# dotfiles-sweep.md D2). quickshell is GONE; the old `qs ipc music` bridge
# becomes playerctl (MPRIS). Interim scaffolding — eventual nix-native shape is
# writeShellApplication with declared deps.
case "$1" in
    play|toggle)  playerctl play-pause ;;
    next)         playerctl next ;;
    prev)         playerctl previous ;;
    *)            echo "Usage: $0 {play|next|prev}"; exit 1 ;;
esac
