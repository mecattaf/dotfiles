#!/usr/bin/env bash
# niri Mod+Shift+Return:
#   - coordinator: open a new kitty in the cwd of whatever's running in
#     the focused kitty — prefer a descendant nvim's cwd, fall back to the
#     shell's cwd, fall back to kitty's cwd. Mirrors the old scroll
#     nvim-terminal.lua philosophy (without the Lua or IDE-split gymnastics).
#     Every local terminal is a persistent zmx session (jul7 "every kitty is a
#     projector" ruling) — so it can be reattached from any other box via
#     `kitten ssh coordinator -t zmx attach`.
#
#     LATENCY + UNIQUENESS (fixed after #38's botched titling): the session
#     name is derived SELF-CONTAINED and UNIQUE per invocation
#     (cwd-basename + HHMMSS + random) — no flm, no network, no blocking
#     subprocess in the spawn path, so every Mod+Shift+Return is instant and
#     always a BRAND-NEW independent session (two presses in the same second
#     never collide, so kitty never mirrors an existing session). The richer
#     LLM title (#38) is now applied ASYNCHRONOUSLY and purely COSMETICALLY by
#     `zmx-retitle` after the window is already up: it retitles the kitty
#     window only (zmx has no rename/display-name concept — the session name
#     IS its identity) and silently no-ops on any failure. It NEVER changes
#     the session name and NEVER delays the launch.
#   - elsewhere (worker / zenbook thin-client): open a new kitty that
#     immediately SSHs to coordinator via the `desk` fish function; niri's
#     window-rule renders the white "remote" border once desk sets the title.

set -u

# One session universe regardless of entry path (see zmx-annotate header):
# pin zmx's socket dir so local niri spawns (XDG_RUNTIME_DIR set) land in the
# same /tmp/zmx-$UID universe as kitten-ssh desk attaches (XDG unset there).
export ZMX_DIR="${ZMX_DIR:-/tmp/zmx-$(id -u)}"

host="$(hostname)"

if [[ "$host" != "coordinator" ]]; then
    exec kitty fish -ic desk
fi

focused=$(niri msg -j focused-window 2>/dev/null || true)
app_id=$(printf '%s' "$focused" | jq -r '.app_id // empty' 2>/dev/null)
pid=$(printf '%s' "$focused" | jq -r '.pid // empty' 2>/dev/null)

cwd=""

# Recursively find a nvim descendant of the kitty pid and return its cwd.
find_nvim_cwd() {
    local parent=$1 child comm
    for child in $(pgrep -P "$parent" 2>/dev/null); do
        comm=$(ps -p "$child" -o comm= 2>/dev/null)
        if [[ "$comm" =~ ^n?vim$ ]]; then
            readlink "/proc/$child/cwd" 2>/dev/null
            return 0
        fi
        if find_nvim_cwd "$child"; then
            return 0
        fi
    done
    return 1
}

if [[ "$app_id" == "kitty" && -n "$pid" ]]; then
    cwd=$(find_nvim_cwd "$pid" || true)
    if [[ -z "$cwd" ]]; then
        shell_pid=$(pgrep -P "$pid" 2>/dev/null | head -n1)
        [[ -n "$shell_pid" ]] && cwd=$(readlink "/proc/$shell_pid/cwd" 2>/dev/null || true)
    fi
    [[ -z "$cwd" ]] && cwd=$(readlink "/proc/$pid/cwd" 2>/dev/null || true)
fi

# Unique, self-contained session identity: cwd basename + wallclock + random.
# NO flm, NO network, NO blocking subprocess — this is the whole point of the
# fix. The basename is sanitised to a safe token (also used verbatim as the
# kitty remote-control socket name below). The random suffix (6 hex from the
# kernel RNG) guarantees a fresh, independent session even when two launches
# land in the same second from the same directory.
base="$(basename "${cwd:-$HOME}")"
base="$(printf '%s' "$base" | LC_ALL=C sed 's/[^A-Za-z0-9._-]/_/g')"
[[ -n "$base" ]] || base="term"
rand="$(cut -c1-6 /proc/sys/kernel/random/uuid 2>/dev/null || printf '%s' "$$")"
sess="${base}-$(date +%H%M%S)-${rand}"

# Per-window kitty remote-control socket, keyed off the unique session name, so
# the async titler can target THIS window (and only this one). kitty.conf sets
# `allow_remote_control yes` globally; --listen-on overrides the per-instance
# socket. We deliberately do NOT pass --title (that would FIX the wayland/OS
# title and block the cosmetic retitle from ever showing in niri).
sock="unix:@zmx-${sess}"

# Fire-and-forget the ASYNC cosmetic titler. `setsid` + redirected stdio fully
# detaches it so it survives the `exec kitty` below, never holds a terminal,
# and cannot delay the launch. It polls the socket, asks flm for a nicer name
# (via zmx-title, with its own hard timeout) and, only if flm actually enriches
# the name, retitles the kitty window. On ANY failure — flm down, ZMX_TITLE=0,
# no kitten — it silently no-ops, leaving the natural terminal title. It NEVER
# touches the zmx session name.
if [[ "${ZMX_TITLE:-1}" == "1" ]]; then
    setsid "$(dirname "$0")/zmx-retitle" "$sock" "$sess" "${cwd:-$HOME}" \
        </dev/null >/dev/null 2>&1 &
fi

if [[ -n "$cwd" && -d "$cwd" ]]; then
    exec kitty -o allow_remote_control=yes --listen-on "$sock" \
        --directory "$cwd" -e zmx attach "$sess" fish
fi

exec kitty -o allow_remote_control=yes --listen-on "$sock" \
    -e zmx attach "$sess" fish
