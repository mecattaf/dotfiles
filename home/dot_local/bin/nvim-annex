#!/usr/bin/env bash
# nvim-annex — Ctrl+G externalized composer, IN-PLACE (dotfiles#49; model
# revised by Tom 2026-07-15).
#
# THE MODEL: on Ctrl+G the main Claude window TRANSFORMS INTO the nvim entry box
# (bottom half), and a single read-only transcript viewer is stacked above it
# (top half) by the Ctrl+G kitten (annex_view.py). There is deliberately NO
# separate composer window and NO blank harness — the earlier design spawned the
# composer in its own os-window to avoid Claude blanking its renderer, but the
# viewer now covers the conversation, so we WANT the in-place transform.
#
# HOW: Claude Code / pi resolve $EDITOR/$VISUAL to this wrapper (scoped by
# functions/_annex_editor.fish) and spawn it SYNCHRONOUSLY with stdio inherited
# (spawnSync), reading the tempfile back on exit. So running nvim RIGHT HERE, in
# the inherited terminal, makes nvim take over the Claude window — the transform.
# The basename `nvim-annex` is LOAD-BEARING: Claude classifies the editor by
# basename against \b(vi|vim|nvim|...)\b; `nvim-annex` matches \bnvim\b so Claude
# takes the BLOCKING spawnSync branch (an unmatched name would spawn detached and
# read the unchanged file back, losing the compose).
#
# EXIT CODE: unlike the retired os-window design, nvim is a DIRECT child in the
# harness's own pty here — no zmx `attach` layer masks its status — so nvim's real
# exit code is reliable and is what both harnesses gate the re-read on (Claude:
# `c.status!==0 -> content:null`; pi: `if(status===0) setText(...)`). :wq -> 0
# (harness applies the edit), :cq / crash -> nonzero (harness keeps the original).
# No tempfile-mtime dance needed anymore (that existed only to work around zmx
# masking the exit code of the old windowed composer).
set -u

# Run the composer in place. "$@" is Claude's/pi's draft tempfile (absolute).
nvim "$@"
rc=$?

# Reap the transcript viewer stacked above us so the harness reflows back to full
# height — niri auto-refills a column when its top window closes (verified). The
# newest annex-viewer window is the one this compose spawned (annex_view.py
# dedups per session, so there is normally exactly one). Best-effort: any failure
# just leaves the viewer up for a manual Ctrl+Shift+O dismiss.
vid="$(niri msg -j windows 2>/dev/null \
	| jq -re 'map(select(.app_id=="annex-viewer")) | max_by(.id) | .id // empty' 2>/dev/null)"
[ -n "$vid" ] && niri msg action close-window --id "$vid" >/dev/null 2>&1

exit "$rc"
