#!/bin/bash
# pomo -- simple Pomodoro timer (file-based state, no quickshell IPC)

if [ "$(uname)" == "Darwin" ] || [ "${POMO_PREFIX_CMDS}" == "true" ]; then
    DATE_CMD="gdate"
    STAT_CMD="gstat"
else
    DATE_CMD="date"
    STAT_CMD="stat"
fi

[[ -n $POMO_FILE ]] && POMO=$POMO_FILE || POMO=$HOME/.local/share/pomo
[[ -n $POMO_WORK_TIME ]] && WORK_TIME=$POMO_WORK_TIME || WORK_TIME=25
[[ -n $POMO_BREAK_TIME ]] && BREAK_TIME=$POMO_BREAK_TIME || BREAK_TIME=5

function pomo_start {
    test -e "$(dirname -- "$POMO")" || mkdir "$(dirname -- "$POMO")"
    :> "$POMO"
    touch "$POMO"
}

function pomo_isstopped {
    [[ ! -e "$POMO" ]]
    return $?
}

function pomo_stop {
    rm -f "$POMO"
}

function pomo_stamp {
    ago=$1
    mtime=$(${DATE_CMD} --date "@$(( $(date +%s) - ago))" +%m%d%H%M.%S)
    :> "$POMO"
    touch -m -t "$mtime" "$POMO"
}

function pomo_ispaused {
    [[ $(wc -l < "$POMO") -gt 0 ]]
    return $?
}

function pomo_pause {
    running=$(pomo_stat)
    if pomo_isstopped || pomo_ispaused; then
        pomo_stamp "$running"
    else
        echo "$running" > "$POMO"
    fi
}

function pomo_update {
    running=$(pomo_stat)
    block_time=$(( (WORK_TIME+BREAK_TIME)*60 ))
    if [[ $running -ge $block_time ]]; then
        ago=$(( running % block_time ))
        mtime=$(${DATE_CMD} --date "@$(( $(date +%s) - ago))" +%m%d%H%M.%S)
        touch -m -t "$mtime" "$POMO"
    fi
}

function pomo_stat {
    [[ -e "$POMO" ]] && running=$(cat "$POMO") || running=0
    if [[ -z $running ]]; then
        pomo_start=$(${STAT_CMD} -c +%Y "$POMO")
        now=$(${DATE_CMD} +%s)
        running=$((now-pomo_start))
    fi
    echo $running
}

function pomo_clock {
    if ! pomo_isstopped; then
        pomo_update
        running=$(pomo_stat)
        left=$(( WORK_TIME*60 - running ))
        if [[ $left -lt 0 ]]; then
            left=$(( left + BREAK_TIME*60 ))
            prefix=$'\U0001F334'
        else
            prefix=$'\U0001F345'
        fi
        pomo_ispaused && prefix=$'\U000023F8'$prefix
        min=$(( left / 60 ))
        sec=$(( left - 60*min ))
        printf "%2s%02d:%02d\n" $prefix $min $sec
    else
        printf "  --:--\n"
    fi
}

function pomo_emoji {
    if ! pomo_isstopped; then
        pomo_update
        running=$(pomo_stat)
        left=$(( WORK_TIME*60 - running ))
        if [[ $left -lt 0 ]]; then
            prefix=$'\U0001F3D6'
        else
            prefix=$'\U0001F345'
        fi
        pomo_ispaused && prefix=$'\U000023F8'
        printf $prefix
    else
        printf "  --:--\n"
    fi
}

function pomo_minutes {
    if ! pomo_isstopped; then
        pomo_update
        running=$(pomo_stat)
        left=$(( WORK_TIME*60 - running ))
        if [[ $left -lt 0 ]]; then
            left=$(( left + BREAK_TIME*60 ))
        fi
        min=$(( left / 60 ))
        printf $min
    else
        printf "  --:--\n"
    fi
}

function pomo_seconds {
    if ! pomo_isstopped; then
        pomo_update
        running=$(pomo_stat)
        left=$(( WORK_TIME*60 - running ))
        if [[ $left -lt 0 ]]; then
            left=$(( left + BREAK_TIME*60 ))
        fi
        min=$(( left / 60 ))
        sec=$(( left - 60*min ))
        printf $sec
    else
        printf "  --:--\n"
    fi
}

function pomo_status {
    while true; do
        pomo_clock
        sleep 1
    done
}

function pomo_msg {
    break_end_msg='End of a break period. Time for work!'
    work_end_msg='End of a work period. Time for a break!'
    [[ -e "$POMO" ]] || return 1
    pomo_update
    running=$(pomo_stat)
    while true; do
        left=$(( WORK_TIME*60 - running ))
        work=true
        if [[ $left -lt 0 ]]; then
            left=$(( left + BREAK_TIME*60 ))
            work=false
        fi
        sleep $left
        stat=$(pomo_stat)
        [[ $stat -ge $(( running + left )) ]] && break
        $work || { [[ $stat -lt $running ]] && break; }
        running=$stat
    done
    if [[ $(( stat - running - left )) -le 1 ]]; then
        if $work; then
            send_msg "$work_end_msg"
        else
            send_msg "$break_end_msg"
        fi
    fi
    return 0
}

function pomo_notify {
    while true; do
        if pomo_msg; then
            sleep 1
        else
            sleep 60
        fi
    done
}

function send_msg {
    if [ "$(uname)" == "Darwin" ]; then
        osascript -e "tell app \"System Events\" to display dialog \"${1}\"" &> /dev/null
    elif command -v notify-send &> /dev/null; then
        notify-send Pomodoro "${1}"
    else
        echo "${1}"
    fi
}

function pomo_usage {
    cat <<END
pomo [-h] [start | stop | pause | clock | status | notify | usage]

A simple Pomodoro timer.

Actions:
  start    Start Pomodoro timer.
  stop     Stop Pomodoro timer.
  pause    Pause/resume the timer.
  clock    Print time remaining in current cycle.
  notify   Raise notifications at end of each work/break block (infinite loop).
  status   Continuously print status once per second.
  usage    Print this message.

Environment variables:
  POMO_FILE        Location of pomo state file. Default: \$HOME/.local/share/pomo
  POMO_WORK_TIME   Work period in minutes. Default: 25
  POMO_BREAK_TIME  Break period in minutes. Default: 5
END
}

action=
while getopts h arg; do
    case $arg in
        h|?) action=usage ;;
    esac
done
shift $((OPTIND-1))

actions="start stop pause clock usage notify status emoji minutes seconds"
for act in $actions; do
    if [[ $act == "$1" ]]; then
        action=$act
        break
    fi
done

if [[ -n $action ]]; then
    pomo_"$action"
else
    [[ $# -gt 0 ]] && echo "Unknown option/action: $1." || echo "Action not supplied."
    pomo_usage
fi
