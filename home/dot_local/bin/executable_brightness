#!/bin/bash
# brightness -- adjust display brightness via IPC
# IPC target: display (BrightnessBridge IpcHandler)
case "$1" in
    up)    qs ipc --pid $(pgrep -x qs) call display brighter 0.05 ;;
    down)  qs ipc --pid $(pgrep -x qs) call display dimmer 0.05 ;;
    *)     echo "Usage: $0 {up|down}"; exit 1 ;;
esac
