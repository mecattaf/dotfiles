#!/bin/bash
# UNCHANGED: brightness IPC commands stay the same
# BrightnessBridge (via display IPC target) handles OSD automatically
case "$1" in
    up)    quickshell ipc call display brighter 0.05 ;;
    down)  quickshell ipc call display dimmer 0.05 ;;
    *)     echo "Usage: $0 {up|down}"; exit 1 ;;
esac
