#!/usr/bin/env bash
# wallpaper -- set desktop wallpaper via IPC
# IPC target: wallpaper (WallpaperBridge IpcHandler), method: change <path>
DEFAULT="/usr/share/backgrounds/harness/wallpaper.jpg"
path="${1:-$DEFAULT}"

if [[ ! -f "$path" ]]; then
    echo "File not found: $path" >&2
    exit 1
fi

qs ipc --pid $(pgrep -x qs) call wallpaper change "$path"
