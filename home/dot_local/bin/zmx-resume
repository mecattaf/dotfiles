#!/usr/bin/env bash
# fzf-pick an existing local zmx session and attach to it. Runs on the
# coordinator. Companion to `new-terminal` / `desk`, which always spawn a
# *fresh* session. The remote equivalent (worker / zenbook thin-client) lives in
# remote.fish (`desk-resume`), which lists over ssh and attaches over kitten ssh.

set -u

command -v zmx >/dev/null 2>&1 || { echo "zmx not found on $(hostname)" >&2; exit 1; }
command -v fzf >/dev/null 2>&1 || { echo "fzf not found on $(hostname)" >&2; exit 1; }

# Same-universe guard as zmx-annotate/new-terminal (see zmx-annotate header).
export ZMX_DIR="${ZMX_DIR:-/tmp/zmx-$(id -u)}"

# Session names are unique, self-contained identities (cwd-basename + HHMMSS +
# random) rather than LLM titles, so we enrich the PICKER instead: zmx-annotate
# joins `zmx list` with the sidecar title store (flm titles persisted by
# zmx-retitle, backfilled from scrollback for sessions that never ran the
# titler) plus start_dir/age/attached — all read instantly from the filesystem,
# no LLM call in this path (issue #38's real point). fzf shows only the display
# field; we attach by the name (field 1). If zmx-annotate yields nothing
# (format drift), fall back to the plain `--short` name list, duplicated into
# both fields so the fzf invocation below still renders it.
picker="$("$(dirname "$0")/zmx-annotate" 2>/dev/null)"
[[ -n "$picker" ]] || picker="$(zmx list --short 2>/dev/null | awk '{printf "%s\t%s\n", $0, $0}')"

sess=$(printf '%s\n' "$picker" \
    | fzf --prompt='resume> ' --no-sort --delimiter='\t' --with-nth='2..' \
    | cut -f1)
[[ -n "$sess" ]] || exit 0

exec zmx attach "$sess"
