#!/bin/bash
# screenshot -- take a screenshot using niri native actions
# No quickshell IPC. Uses niri msg action.
case "${1:-full}" in
    full)    niri msg action screenshot-screen ;;
    area)    niri msg action screenshot ;;
    window)  niri msg action screenshot-window ;;
    *)       echo "Usage: $0 {full|area|window}"; exit 1 ;;
esac
