    "hf_inspections": 4,
    "baseline_rationale_chars": 40000,
    "git_timeout_seconds": 300,
    "model_timeout_seconds": 1800
  },
  "hardware_context": {
    "nodes": [
      {
        "name": "coordinator",
        "hardware": "AMD Ryzen AI MAX+ 395, Radeon 8060S gfx1151, 128 GiB unified RAM",
        "policy": "XDNA NPU enabled; IOMMU enabled in translated mode",
        "roles": ["Tally coordinator", "Pi harness", "Git and PR mechanics"]
      },
      {
        "name": "worker",
        "hardware": "AMD Ryzen AI MAX+ 395, Radeon 8060S gfx1151, 128 GiB unified RAM",
        "policy": "NPU disabled; IOMMU disabled for iGPU and DS4 performance",
        "roles": ["llama-swap model host", "primary GPU inference"]
      }
    ],
    "runtime_policy": "Every local LLM call goes through llama-swap; stable diffusion is outside this route.",
