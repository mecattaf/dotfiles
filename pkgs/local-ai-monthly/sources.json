{
  "schema_version": 1,
  "accepted_through": "2026-07-21",
  "inference": {
    "provider": "llama-swap",
    "url": "http://worker-tb:9292",
    "model_class": "strongest",
    "fallback_classes": ["fast"],
    "classes": {
      "strongest": {
        "role_order": ["quality", "general"],
        "ram_order": "descending"
      },
      "fast": {
        "role_order": ["utility", "general"],
        "ram_order": "ascending"
      }
    },
    "execution_host": "coordinator",
    "compute_host": "worker",
    "tally_pool": "worker-gpu"
  },
