{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mecattaf.dev/schemas/local-ai-monthly-brief-v1.json",
  "title": "Local-AI monthly repository brief",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "task_id",
    "source",
    "scope",
    "findings",
    "roster_proposals",
    "decision",
    "status"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "task_id": { "type": "string", "minLength": 1 },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["slug", "baseline_sha", "observed_head_sha", "comparison_kind", "commit_count"],
      "properties": {
        "slug": { "type": "string", "minLength": 1 },
        "baseline_sha": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
        "observed_head_sha": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
        "comparison_kind": { "type": "string", "minLength": 1 },
        "commit_count": { "type": "integer", "minimum": 1 }
      }
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["partition", "inspected_evidence_ids", "omitted_evidence_ids"],
      "properties": {
        "partition": { "type": "string", "minLength": 1 },
        "inspected_evidence_ids": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "omitted_evidence_ids": { "type": "array", "maxItems": 0 }
      }
    },
    "findings": { "type": "array", "items": { "$ref": "#/$defs/finding" } },
    "roster_proposals": { "type": "array", "items": { "$ref": "#/$defs/rosterProposal" } },
    "decision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["action", "confidence", "unresolved_questions", "next_baseline_sha"],
      "properties": {
        "action": { "enum": ["adopt", "watch", "test", "ignore"] },
        "confidence": { "enum": ["high", "medium", "low"] },
        "unresolved_questions": { "type": "array", "items": { "type": "string" } },
        "next_baseline_sha": { "type": "string", "pattern": "^[0-9a-f]{40}$" }
      }
    },
    "status": { "const": "complete" }
  },
  "$defs": {
    "finding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "change_class", "summary", "hardware_relevance", "nix_relevance", "topics", "evidence_ids", "derived_from"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "kind": { "enum": ["claim", "measurement", "inference"] },
        "change_class": { "enum": ["new-model", "new-quant", "new-runtime", "new-backend", "new-draft-method", "corrected-claim", "negative-result", "strict-supersession-candidate", "platform-policy", "packaging", "benchmark", "other"] },
        "summary": { "type": "string", "minLength": 1 },
        "hardware_relevance": { "type": "string", "minLength": 1 },
        "nix_relevance": { "type": "string", "minLength": 1 },
        "topics": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "evidence_ids": { "type": "array", "minItems": 1, "items": { "type": "string" }, "uniqueItems": true },
        "derived_from": { "type": "array", "items": { "type": "string" }, "uniqueItems": true }
      }
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["hf_url", "revision", "files", "runtime_repo", "runtime_commit", "backend", "hosts"],
      "properties": {
        "hf_url": { "type": ["string", "null"] },
        "revision": { "type": ["string", "null"] },
        "files": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["path", "bytes", "sha256"],
            "properties": {
              "path": { "type": "string" },
              "bytes": { "type": ["integer", "null"], "minimum": 0 },
              "sha256": { "type": ["string", "null"] }
            }
          }
        },
        "runtime_repo": { "type": ["string", "null"] },
        "runtime_commit": { "type": ["string", "null"] },
        "backend": { "type": ["string", "null"] },
        "hosts": { "type": "array", "items": { "enum": ["coordinator", "worker"] }, "uniqueItems": true }
      }
    },
    "rosterProposal": {
      "type": "object",
      "additionalProperties": false,
      "required": ["action", "relationship", "stable_model_id", "comparison_targets", "improvement_axes", "reason", "evidence_ids", "hf_inspection_id", "artifact", "unresolved_fields"],
      "properties": {
        "action": { "enum": ["investigate", "add", "update", "retire"] },
        "relationship": { "enum": ["net-add", "additional-option", "technical-upgrade", "strict-supersession", "no-roster-change"] },
        "stable_model_id": { "type": "string", "minLength": 1 },
        "comparison_targets": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "improvement_axes": { "type": "array", "items": { "enum": ["quality", "speed", "memory", "context", "tool-use", "reasoning", "multimodal", "backend", "mtp-draft", "topology", "reproducibility", "license", "other"] }, "uniqueItems": true },
        "reason": { "type": "string", "minLength": 1 },
        "evidence_ids": { "type": "array", "minItems": 1, "items": { "type": "string" }, "uniqueItems": true },
        "hf_inspection_id": { "type": ["string", "null"] },
        "artifact": { "$ref": "#/$defs/artifact" },
        "unresolved_fields": { "type": "array", "items": { "type": "string" }, "uniqueItems": true }
      }
    }
  }
}
