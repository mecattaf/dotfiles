        "format": "{:%M}",
    },
    "clock#3": {
		"interval": 60,
        "format": "{:%p}",
    },

	// waybar-cpu

	// waybar-custom
    "custom/pomo": {
         "format": "{}",
         "exec": "~/.local/share/bin/pomo emoji",
         "tooltip": false,
         "interval" : 1,
         "on-click": "~/.local/share/bin/pomo pause",
    },

    "custom/minutes": {
         "format": "{}",
         "exec": "~/.local/share/bin/pomo minutes",
         "tooltip": false,
         "interval" : 1,
         "on-click": "~/.local/share/bin/pomo pause",
    },

    "custom/seconds": {
         "format": "{}",
         "exec": "~/.local/share/bin/pomo seconds",
         "tooltip": false,
         "interval" : 1,
         "on-click": "~/.local/share/bin/pomo pause",
    },

